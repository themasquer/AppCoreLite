@model DataAccessDemo.Entities.ProductModel
    
@{
	string message;
	string color;
}
@if (ViewBag.Message != null)
{
	message = ViewBag.Message.ToString();
	color = "success";
	if (message.EndsWith("!"))
	{
		color = "danger";
	}
	<p class="text-@color">
		@message
	</p>
}
@if (TempData["Message"] != null)
{
	message = TempData["Message"].ToString();
	color = "success";
	if (message.EndsWith("!"))
	{
		color = "danger";
	}
	<p class="text-@color">
		@message
	</p>
}
    
@{
    ViewData["Title"] = "Detay";
}

<h1>@ViewData["Title"]</h1>

@if (Model != null)
{
    <div>
        <h4>Ürün</h4>
        <hr />
        <dl class="row">
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.Name)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.Name)
            </dd>
             <dt class="col-2">
                @Html.DisplayNameFor(model => model.Description)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.Description)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.CategoryDisplay)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.CategoryDisplay)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.StoresDisplay)
            </dt>
            <dd class="col-10">
                @Html.Raw(Model.StoresDisplay)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.UnitPriceDisplay)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.UnitPriceDisplay)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.UnitPriceTextDisplay)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.UnitPriceTextDisplay)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.StockAmount)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.StockAmount)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.ExpirationDateDisplay)
            </dt>
            <dd class="col-10">
                @Html.DisplayFor(model => model.ExpirationDateDisplay)
            </dd>
            <dt class="col-2">
                @Html.DisplayNameFor(model => model.FileContent)
            </dt>
            <dd class="col-3">
                @if (!string.IsNullOrWhiteSpace(Model.FileContent))
                {
                    <img src="@Model.FileContent" class="img-fluid " />
                }
            </dd>
        </dl>
    </div>
    <div>
        <a asp-action="Edit" asp-route-id="@Model?.Id">Düzenle</a>&nbsp;|&nbsp;
        <a asp-action="Index" asp-route-usePageOrderFilterSession="true">Listeye Geri Dön</a>
    </div>
}
